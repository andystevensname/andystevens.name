---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedItem from '../../components/FeedItem.astro';
import { mapAlbums, sortByDate } from '../../lib/feed';

const albums = await getCollection('albums', ({ data }) => data.published !== false);
const feed = sortByDate(mapAlbums(albums));
---

<Layout title="Albums" description="Photo albums.">
  <h1>Albums</h1>
  <div class="recent-feed h-feed">
    <span class="p-name" style="display:none" aria-hidden="true">Andy Stevens — Albums</span>
    <a class="p-author h-card" href="https://andystevens.name" style="display:none" aria-hidden="true">Andy Stevens</a>
    {feed.length > 0
      ? feed.map((item) => <FeedItem {...item} />)
      : <p>No albums yet.</p>
    }
  </div>
</Layout>
