---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedList from '../../components/FeedList.astro';
import { mapAlbums, sortByDate } from '../../lib/feed';

const [albums, photos] = await Promise.all([
  getCollection('albums', ({ data }) => data.published !== false),
  getCollection('photos', ({ data }) => data.published !== false),
]);
const feed = sortByDate(mapAlbums(albums, photos));
---

<Layout title="Albums" description="Photo albums.">
  <FeedList title="Albums" feed={feed} emptyMessage="No albums yet." class="feed-item--album" />
</Layout>
