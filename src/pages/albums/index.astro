---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedList from '../../components/FeedList.astro';
import { mapAlbums, sortByDate } from '../../lib/feed';

const albums = await getCollection('albums', ({ data }) => data.published !== false);
const feed = sortByDate(mapAlbums(albums));
---

<Layout title="Albums" description="Photo albums.">
  <FeedList title="Albums" feed={feed} emptyMessage="No albums yet." />
</Layout>
