---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedList from '../../components/FeedList.astro';
import { mapBookmarks, sortByDate } from '../../lib/feed';

const bookmarks = await getCollection('bookmarks', ({ data }) => data.published !== false);
const feed = sortByDate(mapBookmarks(bookmarks));
---

<Layout title="Bookmarks" description="Links and bookmarks I've saved.">
  <FeedList title="Bookmarks" feed={feed} emptyMessage="No bookmarks yet." type="bookmark" />
</Layout>
