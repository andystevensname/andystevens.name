---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedItem from '../../components/FeedItem.astro';
import { mapNotes, mapBookmarks, mapLikes, mapReplies, sortByDate } from '../../lib/feed';

const [notes, bookmarks, likes, replies] = await Promise.all([
  getCollection('notes', ({ data }) => data.published !== false),
  getCollection('bookmarks', ({ data }) => data.published !== false),
  getCollection('likes', ({ data }) => data.published !== false),
  getCollection('replies', ({ data }) => data.published !== false),
]);

const feed = sortByDate([
  ...mapNotes(notes),
  ...mapBookmarks(bookmarks),
  ...mapLikes(likes),
  ...mapReplies(replies),
]);
---

<Layout
  title="Commonplace"
  description="Notes, bookmarks, likes, and replies collected from around the web."
>
  <h1>Commonplace</h1>

  <nav class="filter-bar" aria-label="Filter by type">
    <button class="filter-btn" aria-pressed="true" data-filter="all">All</button>
    <button class="filter-btn" aria-pressed="false" data-filter="note">Notes</button>
    <button class="filter-btn" aria-pressed="false" data-filter="bookmark">Bookmarks</button>
    <button class="filter-btn" aria-pressed="false" data-filter="like">Likes</button>
    <button class="filter-btn" aria-pressed="false" data-filter="reply">Replies</button>
  </nav>

  <div class="recent-feed h-feed" id="commonplace-feed" aria-live="polite">
    <span class="p-name" style="display:none" aria-hidden="true">Andy Stevens — Commonplace</span>
    <a class="p-author h-card" href="https://andystevens.name" style="display:none" aria-hidden="true">Andy Stevens</a>
    {feed.length > 0
      ? feed.map((item) => <FeedItem {...item} />)
      : <p>Nothing here yet.</p>
    }
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.filter-btn');
    const feed = document.getElementById('commonplace-feed');
    if (!feed || !buttons.length) return;

    function applyFilter(filter: string) {
      const items = feed!.querySelectorAll('.feed-item');

      items.forEach((item) => {
        const category = (item as HTMLElement).dataset.category;
        const show = filter === 'all' || category === filter;
        (item as HTMLElement).style.display = show ? '' : 'none';
      });

      buttons.forEach((btn) => {
        btn.setAttribute('aria-pressed', btn.getAttribute('data-filter') === filter ? 'true' : 'false');
      });

      if (filter === 'all') {
        history.replaceState(null, '', window.location.pathname);
      } else {
        history.replaceState(null, '', `#${filter}`);
      }
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter') ?? 'all';
        applyFilter(filter);
      });
    });

    const hash = window.location.hash.slice(1);
    if (hash) {
      applyFilter(hash);
    }
  });
</script>
