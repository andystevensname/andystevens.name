---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedItem from '../../components/FeedItem.astro';
import { mapNotes, mapBookmarks, mapLikes, mapReplies, sortByDate } from '../../lib/feed';

const [notes, bookmarks, likes, replies] = await Promise.all([
  getCollection('notes', ({ data }) => data.published !== false),
  getCollection('bookmarks', ({ data }) => data.published !== false),
  getCollection('likes', ({ data }) => data.published !== false),
  getCollection('replies', ({ data }) => data.published !== false),
]);

const feed = sortByDate([
  ...mapNotes(notes),
  ...mapBookmarks(bookmarks),
  ...mapLikes(likes),
  ...mapReplies(replies),
]);
---

<Layout
  title="Commonplace"
  description="Notes, bookmarks, likes, and replies collected from around the web."
>
  <h1 class="feed-item--commonplace">Commonplace</h1>

  <div class="filter-container">
    <nav class="filter-bar" aria-label="Filter by type">
      <input type="radio" name="filter" id="filter-all" class="filter-input" value="all" checked />
      <label for="filter-all" class="filter-btn">All</label>
      <input type="radio" name="filter" id="filter-note" class="filter-input" value="note" />
      <label for="filter-note" class="filter-btn">Notes</label>
      <input type="radio" name="filter" id="filter-bookmark" class="filter-input" value="bookmark" />
      <label for="filter-bookmark" class="filter-btn">Bookmarks</label>
      <input type="radio" name="filter" id="filter-like" class="filter-input" value="like" />
      <label for="filter-like" class="filter-btn">Likes</label>
      <input type="radio" name="filter" id="filter-reply" class="filter-input" value="reply" />
      <label for="filter-reply" class="filter-btn">Replies</label>
    </nav>

    <section class="recent-feed h-feed" id="commonplace-feed" aria-live="polite">
      <span class="p-name" style="display:none" aria-hidden="true">Andy Stevens — Commonplace</span>
      <a class="p-author h-card" href="https://andystevens.name" style="display:none" aria-hidden="true">Andy Stevens</a>
      {feed.length > 0
        ? feed.map((item) => <FeedItem {...item} />)
        : <p>Nothing here yet.</p>
      }
    </section>
  </div>
</Layout>
