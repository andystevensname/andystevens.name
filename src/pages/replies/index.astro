---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedList from '../../components/FeedList.astro';
import { mapReplies, sortByDate } from '../../lib/feed';

const replies = await getCollection('replies', ({ data }) => data.published !== false);
const feed = sortByDate(mapReplies(replies));
---

<Layout title="Replies" description="Replies to posts around the web.">
  <FeedList title="Replies" feed={feed} emptyMessage="No replies yet." />
</Layout>
