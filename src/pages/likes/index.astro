---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedList from '../../components/FeedList.astro';
import { mapLikes, sortByDate } from '../../lib/feed';

const likes = await getCollection('likes', ({ data }) => data.published !== false);
const feed = sortByDate(mapLikes(likes));
---

<Layout title="Likes" description="Things I've liked around the web.">
  <FeedList title="Likes" feed={feed} emptyMessage="No likes yet." class="feed-item--like" />
</Layout>
