---
import Layout from '../layouts/Layout.astro';
import FeedItem from '../components/FeedItem.astro';
import { getCollection } from 'astro:content';
import { mapArticles, mapNotes, mapBookmarks, mapLikes, mapAlbums, mapReplies, mapWriting, mapAwards, mapCode, sortByDate } from '../lib/feed';

const [posts, notes, bookmarks, likes, albums, photos, replies, writing, awards, code] = await Promise.all([
  getCollection('articles', ({ data }) => data.published !== false),
  getCollection('notes', ({ data }) => data.published !== false),
  getCollection('bookmarks', ({ data }) => data.published !== false),
  getCollection('likes', ({ data }) => data.published !== false),
  getCollection('albums', ({ data }) => data.published !== false),
  getCollection('photos'),
  getCollection('replies', ({ data }) => data.published !== false),
  getCollection('writing', ({ data }) => data.published !== false),
  getCollection('awards', ({ data }) => data.published !== false),
  getCollection('code', ({ data }) => data.published !== false),
]);

const feed = sortByDate([
  ...mapArticles(posts),
  ...mapNotes(notes),
  ...mapBookmarks(bookmarks),
  ...mapLikes(likes),
  ...mapAlbums(albums, photos),
  ...mapReplies(replies),
  ...mapWriting(writing),
  ...mapAwards(awards),
  ...mapCode(code),
]);

const recent = feed.slice(0, 20);
---

<Layout
  description="The homepage of poet and writer Andy Stevens."
>
  <h1>Recent</h1>
  <section class="recent-feed h-feed">
    <span class="p-name" style="display:none" aria-hidden="true">Andy Stevens</span>
    <a class="p-author h-card" href="https://andystevens.name" style="display:none" aria-hidden="true">Andy Stevens</a>
    {recent.map((item) => <FeedItem {...item} />)}
  </section>
</Layout>
