---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedList from '../../components/FeedList.astro';
import { mapBlogPosts, sortByDate } from '../../lib/feed';

const posts = await getCollection('blog', ({ data }) => data.published !== false);
const feed = sortByDate(mapBlogPosts(posts));
---

<Layout title="Blog" description="A listing of all blogs, articles, and missives.">
  <FeedList title="Blog" feed={feed} emptyMessage="No articles found." />
</Layout>
