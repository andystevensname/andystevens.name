---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedItem from '../../components/FeedItem.astro';
import { mapBlogPosts, sortByDate } from '../../lib/feed';

const posts = await getCollection('blog', ({ data }) => data.published !== false);
const feed = sortByDate(mapBlogPosts(posts));
---

<Layout
  title="Blog"
  description="A listing of all blogs, articles, and missives."
>
  <h1>Blog</h1>
  <div class="recent-feed h-feed">
    <span class="p-name" style="display:none" aria-hidden="true">Andy Stevens — Blog</span>
    <a class="p-author h-card" href="https://andystevens.name" style="display:none" aria-hidden="true">Andy Stevens</a>
    {feed.length > 0
      ? feed.map((item) => <FeedItem {...item} />)
      : <p>No articles found.</p>
    }
  </div>
</Layout>
