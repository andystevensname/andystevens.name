---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedItem from '../../components/FeedItem.astro';
import { mapWriting, mapAwards, sortByDate } from '../../lib/feed';

const [writing, awards] = await Promise.all([
  getCollection('writing', ({ data }) => data.published !== false),
  getCollection('awards', ({ data }) => data.published !== false),
]);

const feed = sortByDate([
  ...mapWriting(writing),
  ...mapAwards(awards),
]);

const categories = [...new Set(writing.map((w) => w.data.category))].sort();
---

<Layout title="Writing" description="Publications, writing, and awards.">
  <h1 class="feed-item--writing">Writing</h1>

  <div class="filter-container">
    <nav class="filter-bar" aria-label="Filter by category">
      <input type="radio" name="filter" id="filter-all" class="filter-input" value="all" checked />
      <label for="filter-all" class="filter-btn">All</label>
      {categories.map((cat) => (
        <>
          <input type="radio" name="filter" id={`filter-${cat}`} class="filter-input" value={cat} />
          <label for={`filter-${cat}`} class="filter-btn">{cat.charAt(0).toUpperCase() + cat.slice(1)}</label>
        </>
      ))}
      <input type="radio" name="filter" id="filter-award" class="filter-input" value="award" />
      <label for="filter-award" class="filter-btn">Awards</label>
    </nav>

    <section class="recent-feed" id="writing-feed" aria-live="polite">
      {feed.length > 0
        ? feed.map((item) => <FeedItem {...item} />)
        : <p>Nothing here yet.</p>
      }
    </section>
  </div>
</Layout>
