---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Offline" description="You're currently offline.">
  <h1>You're offline</h1>
  <p>It looks like your connection dropped. Pages you've already visited should still load — try one from the navigation, or reconnect and reload.</p>
  <p><button type="button" onclick="location.reload()">Try again</button></p>
</Layout>
