---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FeedItem from '../../components/FeedItem.astro';
import { mapPhotos, sortByDate } from '../../lib/feed';

const photos = await getCollection('photos', ({ data }) => data.published !== false);
const feed = sortByDate(mapPhotos(photos));
---

<Layout title="Photos" description="Photos I've shared.">
  <h1>Photos</h1>
  <div class="recent-feed h-feed">
    <span class="p-name" style="display:none" aria-hidden="true">Andy Stevens — Photos</span>
    <a class="p-author h-card" href="https://andystevens.name" style="display:none" aria-hidden="true">Andy Stevens</a>
    {feed.length > 0
      ? feed.map((item) => <FeedItem {...item} />)
      : <p>No photos yet.</p>
    }
  </div>
</Layout>
