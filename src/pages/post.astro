---
// Stripped-down posting interface. No Layout wrapper — popup-friendly.
// Authentication and submission wired up in subsequent steps; this is
// just the form scaffold with query-param prefill and type switching.
import '../styles/global.css';

// Bookmarklet: opens this same page in a popup with the current page's
// URL, title, and any selected text prefilled as query params. Built as
// a single line so it survives copy-paste into a browser's bookmark URL
// field unchanged.
const BOOKMARKLET = `javascript:(function(){var u=encodeURIComponent(location.href),t=encodeURIComponent(document.title),s=encodeURIComponent(window.getSelection().toString());window.open('https://andystevens.name/post/?url='+u+'&title='+t+'&selection='+s,'andypost','width=560,height=720');})();`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>New post — Andy Stevens</title>
  </head>
  <body class="post-page">
    <main>
      <h1>New post</h1>

      <section id="auth-checking" aria-live="polite">
        <p>Checking authorization…</p>
      </section>

      <section id="auth-prompt" hidden>
        <p>You need to authorize this device to post.</p>
        <button type="button" id="sign-in-btn">Sign in with IndieAuth</button>
      </section>

      <section id="auth-error" hidden role="alert">
        <p class="error-message" id="auth-error-message"></p>
        <button type="button" id="auth-retry-btn">Try again</button>
      </section>

      <noscript>
        <p>This page requires JavaScript to authenticate and submit posts.</p>
      </noscript>

      <section id="post-success" hidden role="status" aria-live="polite">
        <p>Posted! It’ll be live once Netlify finishes rebuilding (usually under a minute).</p>
        <p><a id="post-success-link" target="_blank" rel="noopener">View post</a></p>
        <button type="button" id="post-another-btn">Post another</button>
      </section>

      <form id="post-form" autocomplete="off" hidden>
        <p id="post-form-error" class="error-message" hidden role="alert"></p>

        <fieldset class="post-type">
          <legend>Type</legend>
          <label><input type="radio" name="post-type" value="bookmark" checked /> Bookmark</label>
          <label><input type="radio" name="post-type" value="like" /> Like</label>
          <label><input type="radio" name="post-type" value="reply" /> Reply</label>
        </fieldset>

        <!-- Type-specific URL field. Label and input id swap based on type. -->
        <div class="field">
          <label for="target-url" id="target-url-label">URL to bookmark</label>
          <input id="target-url" name="target-url" type="url" required />
        </div>

        <div class="field" data-show-for="bookmark reply">
          <label for="post-name">Title <span class="optional">(optional)</span></label>
          <input id="post-name" name="name" type="text" />
        </div>

        <div class="field" data-show-for="bookmark reply">
          <label for="post-content">
            <span data-content-label-for="bookmark">Commentary <span class="optional">(optional)</span></span>
            <span data-content-label-for="reply">Reply</span>
          </label>
          <textarea id="post-content" name="content" rows="5"></textarea>
        </div>

        <div class="field">
          <label for="post-summary">Summary <span class="optional">(optional)</span></label>
          <input id="post-summary" name="summary" type="text" />
        </div>

        <div class="field">
          <label for="post-tags">Tags <span class="optional">(comma-separated)</span></label>
          <input id="post-tags" name="tags" type="text" placeholder="indieweb, poetry" />
        </div>

        <div class="field">
          <label for="post-slug">Slug <span class="optional">(optional)</span></label>
          <input id="post-slug" name="mp-slug" type="text" />
        </div>

        <div class="field">
          <label for="post-published">Published</label>
          <input id="post-published" name="published" type="datetime-local" required />
        </div>

        <fieldset class="field" id="syndication-targets">
          <legend>Syndicate to</legend>
          <label><input type="checkbox" name="syndication" value="all" /> All</label>
          <label><input type="checkbox" name="syndication" value="activitypub" /> Fediverse</label>
          <label><input type="checkbox" name="syndication" value="bluesky" /> Bluesky</label>
        </fieldset>

        <div class="actions">
          <button type="submit">Post</button>
        </div>
      </form>

      <details id="bookmarklet-info">
        <summary>Bookmarklet</summary>
        <p>Drag this link to your bookmarks bar:</p>
        <p><a class="bookmarklet" href={BOOKMARKLET}>Post to Andy</a></p>
        <p class="hint">
          Click it from any page to open this form in a popup with the page’s
          URL, title, and any selected text prefilled.
        </p>
      </details>
    </main>

    <script>
      import { ensureToken, startAuth, getToken, clearToken } from '../lib/indieauth';

      // ---- Element references ----
      const form = document.getElementById('post-form') as HTMLFormElement;
      const targetUrl = document.getElementById('target-url') as HTMLInputElement;
      const nameInput = document.getElementById('post-name') as HTMLInputElement;
      const contentInput = document.getElementById('post-content') as HTMLTextAreaElement;
      const publishedInput = document.getElementById('post-published') as HTMLInputElement;

      const checkingPanel = document.getElementById('auth-checking')!;
      const promptPanel = document.getElementById('auth-prompt')!;
      const errorPanel = document.getElementById('auth-error')!;
      const errorMessage = document.getElementById('auth-error-message')!;
      const signInBtn = document.getElementById('sign-in-btn')!;
      const retryBtn = document.getElementById('auth-retry-btn')!;
      const successPanel = document.getElementById('post-success')!;
      const successLink = document.getElementById('post-success-link') as HTMLAnchorElement;
      const postAnotherBtn = document.getElementById('post-another-btn')!;
      const formError = document.getElementById('post-form-error')!;
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

      // ---- Panel state ----
      // Exactly one of these is visible at a time: checking, prompt, error,
      // form, or success.
      const allPanels = [checkingPanel, promptPanel, errorPanel, form, successPanel];
      function showPanel(visible: HTMLElement) {
        for (const el of allPanels) el.hidden = el !== visible;
      }

      signInBtn.addEventListener('click', () => { startAuth(); });
      retryBtn.addEventListener('click', () => { startAuth(); });

      // ---- Run auth check ----
      // Either we have a stored token, we just came back from the
      // authorization endpoint with ?code=&state=, or we need to start
      // the flow. ensureToken() handles the first two cases.
      try {
        const token = await ensureToken();
        if (token) {
          showPanel(form);
        } else {
          showPanel(promptPanel);
        }
      } catch (err) {
        errorMessage.textContent = err instanceof Error ? err.message : String(err);
        showPanel(errorPanel);
      }

      // ---- Prefill from query params: ?url=&title=&selection= ----
      // ensureToken() has already restored them following any callback round-trip.
      const params = new URLSearchParams(window.location.search);
      targetUrl.value = params.get('url') ?? '';
      nameInput.value = params.get('title') ?? '';
      contentInput.value = params.get('selection') ?? '';

      // Auto-fill the published timestamp to now, formatted for datetime-local.
      // Slice strips milliseconds and timezone since the input doesn't accept them;
      // we'll convert back to ISO 8601 (with TZ) on submit.
      const now = new Date();
      const tzOffsetMs = now.getTimezoneOffset() * 60 * 1000;
      publishedInput.value = new Date(now.getTime() - tzOffsetMs).toISOString().slice(0, 16);

      // Type switching: show fields based on data-show-for attribute,
      // swap the URL field label, and toggle the content label variants.
      const typeLabels: Record<string, string> = {
        bookmark: 'URL to bookmark',
        like: 'URL to like',
        reply: 'URL you’re replying to',
      };
      const targetLabel = document.getElementById('target-url-label')!;

      function applyType(type: string) {
        targetLabel.textContent = typeLabels[type] ?? 'URL';

        document.querySelectorAll<HTMLElement>('[data-show-for]').forEach((el) => {
          const allowed = el.dataset.showFor!.split(' ');
          el.hidden = !allowed.includes(type);
        });

        document.querySelectorAll<HTMLElement>('[data-content-label-for]').forEach((el) => {
          el.hidden = el.dataset.contentLabelFor !== type;
        });

        // Reply requires content; bookmark and like don't.
        contentInput.required = type === 'reply';
      }

      form.addEventListener('change', (e) => {
        const t = e.target as HTMLInputElement;
        if (t.name === 'post-type') applyType(t.value);
      });

      applyType('bookmark');

      // ---- Submission ----
      function showFormError(msg: string) {
        formError.textContent = msg;
        formError.hidden = false;
        // Scroll the error into view in case the form is long.
        formError.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      }

      function clearFormError() {
        formError.textContent = '';
        formError.hidden = true;
      }

      function getCurrentType(): 'bookmark' | 'like' | 'reply' {
        const checked = form.querySelector<HTMLInputElement>('input[name="post-type"]:checked');
        return (checked?.value ?? 'bookmark') as 'bookmark' | 'like' | 'reply';
      }

      function setOptional(body: URLSearchParams, key: string, value: FormDataEntryValue | null) {
        if (typeof value !== 'string') return;
        const trimmed = value.trim();
        if (trimmed) body.set(key, trimmed);
      }

      function buildBody(): URLSearchParams {
        const fd = new FormData(form);
        const body = new URLSearchParams();
        body.set('h', 'entry');

        const type = getCurrentType();
        const url = String(fd.get('target-url') ?? '').trim();
        if (type === 'bookmark') body.set('bookmark-of', url);
        else if (type === 'like') body.set('like-of', url);
        else if (type === 'reply') body.set('in-reply-to', url);

        setOptional(body, 'name', fd.get('name'));
        setOptional(body, 'content', fd.get('content'));
        setOptional(body, 'summary', fd.get('summary'));
        setOptional(body, 'mp-slug', fd.get('mp-slug'));

        // Tags: comma-separated → repeated category[]
        const tagsRaw = String(fd.get('tags') ?? '').trim();
        if (tagsRaw) {
          for (const tag of tagsRaw.split(',').map((t) => t.trim()).filter(Boolean)) {
            body.append('category[]', tag);
          }
        }

        // Syndication targets — persisted as the post's `syndication`
        // frontmatter array. The post manifest at data/posts.json carries
        // this array through; consumers gate on it via wantsSyndication()
        // in src/lib/post-sources.mjs (e.g. 'activitypub' for federation,
        // 'bluesky' for the post-to-bluesky build plugin).
        for (const target of fd.getAll('syndication')) {
          if (typeof target === 'string') body.append('syndication[]', target);
        }

        // Published: datetime-local → ISO 8601 with timezone
        const publishedLocal = String(fd.get('published') ?? '');
        if (publishedLocal) {
          // new Date('YYYY-MM-DDTHH:MM') is interpreted as local time;
          // toISOString() emits UTC with a trailing Z. Round-trips cleanly.
          body.set('published', new Date(publishedLocal).toISOString());
        }

        return body;
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearFormError();

        const token = getToken();
        if (!token) {
          // Lost the token between page load and submit somehow — push them
          // back to the sign-in flow.
          showPanel(promptPanel);
          return;
        }

        submitBtn.disabled = true;
        const originalLabel = submitBtn.textContent;
        submitBtn.textContent = 'Posting…';

        try {
          const res = await fetch('https://ik.andystevens.name/micropub', {
            method: 'POST',
            headers: {
              Authorization: `Bearer ${token.access_token}`,
              'Content-Type': 'application/x-www-form-urlencoded',
              Accept: 'application/json',
            },
            body: buildBody().toString(),
          });

          if (res.status === 201 || res.status === 202) {
            const location = res.headers.get('Location');
            if (location) {
              successLink.href = location;
              successLink.textContent = location;
            } else {
              // Server didn't return a Location — fall back to a generic link.
              successLink.href = 'https://andystevens.name/';
              successLink.textContent = 'andystevens.name';
            }
            showPanel(successPanel);
            return;
          }

          if (res.status === 401 || res.status === 403) {
            // Token rejected — clear it and bounce back to sign-in.
            clearToken();
            errorMessage.textContent = 'Token rejected. Please sign in again.';
            showPanel(errorPanel);
            return;
          }

          // Try to surface the server's error description.
          let detail = `${res.status} ${res.statusText}`;
          try {
            const json = await res.clone().json() as { error_description?: string; error?: string };
            if (json.error_description) detail = json.error_description;
            else if (json.error) detail = json.error;
          } catch {
            const text = await res.text().catch(() => '');
            if (text) detail = text.slice(0, 300);
          }
          showFormError(`Submission failed: ${detail}`);
        } catch (err) {
          showFormError(`Network error: ${err instanceof Error ? err.message : String(err)}`);
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = originalLabel;
        }
      });

      // ---- "Post another" — reset and show the form again ----
      postAnotherBtn.addEventListener('click', () => {
        form.reset();
        // Reset doesn't run our type-switching logic — apply manually.
        applyType('bookmark');
        // Re-fill the published timestamp.
        const fresh = new Date();
        publishedInput.value = new Date(
          fresh.getTime() - fresh.getTimezoneOffset() * 60 * 1000,
        ).toISOString().slice(0, 16);
        clearFormError();
        showPanel(form);
      });
    </script>

    <style>
      .post-page {
        max-width: 32rem;
        margin: 0 auto;
        padding: 1rem;
        font-family: Helvetica, Arial, sans-serif;
        color: var(--text);
        background: var(--bg);
      }

      h1 {
        font-size: var(--fs-lg);
        margin: 0 0 1rem;
      }

      fieldset {
        border: var(--border-subtle);
        border-radius: var(--radius-sm);
        padding: 0.5rem 0.75rem;
        margin: 0 0 0.75rem;
      }

      legend {
        font-size: var(--fs-sm);
        padding: 0 0.25rem;
      }

      .post-type label,
      #syndication-targets label {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        margin-right: 0.75rem;
        font-size: 1rem;
      }

      .field {
        margin: 0 0 0.75rem;
      }

      .field > label {
        display: block;
        font-size: 1rem;
        font-weight: 500;
        margin-bottom: 0.25rem;
      }

      .field input[type="text"],
      .field input[type="url"],
      .field input[type="datetime-local"],
      .field textarea {
        width: 100%;
        font: inherit;
        font-size: 1rem;
        padding: 0.5rem;
        border: 1px solid #ccc;
        border-radius: var(--radius-sm);
        background: light-dark(#f8f8f8, #333);
        color: var(--text);
      }

      .field textarea {
        resize: vertical;
        min-height: 6rem;
      }

      .optional {
        font-weight: 400;
        color: var(--c-gray-light);
        font-size: var(--fs-sm);
      }

      [hidden] {
        display: none;
      }

      #auth-checking,
      #auth-prompt,
      #auth-error {
        margin: 0 0 1rem;
      }

      .error-message {
        color: light-dark(#b3261e, #f2b8b5);
        margin: 0 0 0.5rem;
      }

      #post-success {
        padding: 1rem;
        border: var(--border-subtle);
        border-radius: var(--radius-sm);
      }

      #post-success p {
        margin: 0 0 0.75rem;
      }

      #post-another-btn {
        font: inherit;
        font-size: 1rem;
        padding: 0.5rem 1rem;
        background: none;
        border: 1px solid var(--c-gray-lighter);
        border-radius: var(--radius-sm);
        color: var(--text);
        cursor: pointer;
      }

      #bookmarklet-info {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: var(--border-subtle);
        font-size: var(--fs-sm);
      }

      #bookmarklet-info summary {
        cursor: pointer;
        font-weight: 500;
      }

      #bookmarklet-info p {
        margin: 0.5rem 0;
      }

      a.bookmarklet {
        display: inline-block;
        font-size: 1rem;
        font-weight: 500;
        padding: 0.5rem 1rem;
        background: var(--gradient);
        color: white;
        text-decoration: none;
        border-radius: var(--radius-sm);
        cursor: grab;
      }

      #bookmarklet-info .hint {
        color: var(--c-gray-light);
      }

      #sign-in-btn,
      #auth-retry-btn {
        font: inherit;
        font-size: 1rem;
        font-weight: 500;
        padding: 0.5rem 1rem;
        background: var(--gradient);
        color: white;
        border: none;
        border-radius: var(--radius-sm);
        cursor: pointer;
      }

      .actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 1rem;
      }

      .actions button {
        font-size: 1rem;
        font-weight: 500;
        padding: 0.5rem 1.25rem 0.5rem 1rem;
        background: var(--gradient);
        color: white;
        border: none;
        border-radius: var(--radius-sm);
        cursor: pointer;
      }
    </style>
  </body>
</html>
