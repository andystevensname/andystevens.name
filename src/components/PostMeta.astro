---
interface Props {
  post: {
    id: string;
    data: {
      date?: Date;
      tags?: string[];
    };
  };
}

const { post } = Astro.props;

let dateStr = '';
let isoDate = '';
if (post.data.date) {
  const d = new Date(post.data.date);
  const utcDate = new Date(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate());
  dateStr = `${utcDate.getFullYear()}-${String(utcDate.getMonth() + 1).padStart(2, '0')}-${String(utcDate.getDate()).padStart(2, '0')}`;
  isoDate = post.data.date.toISOString();
}

const tags = post.data.tags ?? [];
---

<div>
  <div class="meta">
    {dateStr && <time datetime={isoDate}>{dateStr}</time>}
    {dateStr && tags.length > 0 && <span> &middot; </span>}
    {tags.map((tag) => (
      <a class="p-category" href={`/tags/${tag}/`}>#{tag} </a>
    ))}
  </div>
</div>
