---
interface Props {
  post: {
    id: string;
    data: {
      date?: Date;
      tags?: string[];
    };
  };
}

const { post } = Astro.props;

const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];

let dateStr = '';
let isoDate = '';
if (post.data.date) {
  const d = new Date(post.data.date);
  // Adjust for UTC offset to avoid off-by-one day
  const utcDate = new Date(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate());
  dateStr = `${months[utcDate.getMonth()]} ${utcDate.getDate()}, ${utcDate.getFullYear()}`;
  isoDate = post.data.date.toISOString();
}

const tags = post.data.tags ?? [];
---

<div>
  <div class="meta">
    {dateStr && <time datetime={isoDate}>{dateStr}</time>}
    {dateStr && tags.length > 0 && <span> &middot; </span>}
    {tags.map((tag) => (
      <a class="p-category" href={`/blog/tags/${tag}/`}>#{tag} </a>
    ))}
  </div>
</div>
