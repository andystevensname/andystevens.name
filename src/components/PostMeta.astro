---
import { formatDate } from '../lib/date';
import iconsUrl from '../assets/icons.svg?url';

interface Props {
  post: {
    id: string;
    data: {
      date?: Date;
      tags?: string[];
    };
  };
}

const { post } = Astro.props;

const dateStr = post.data.date ? formatDate(new Date(post.data.date)) : '';
const isoDate = post.data.date?.toISOString() ?? '';
const tags = post.data.tags ?? [];
---

<footer class="post-meta-footer">
  <div class="post-meta-footer-row">
    {dateStr && <time datetime={isoDate}>{dateStr}</time>}
    {dateStr && tags.length > 0 && <span> &middot; </span>}
    {tags.map((tag) => (
      <a class="p-category" href={`/tags/${tag}/`}>#{tag} </a>
    ))}
  </div>
  <button id="share-btn" type="button" title="Share this post" class="filter-btn share-btn">
    <span>Share</span>
    <svg class="share-icon icon" width="20" height="20" aria-hidden="true">
      <use href={`${iconsUrl}#icon-share-ios`} />
    </svg>
  </button>
  <div id="share-dialog" class="popover-card" popover role="dialog" aria-label="Share this post">
    <div class="popover-handle" aria-hidden="true"></div>
    <form class="popover-form">
      <p>Copy the link below to share this page.</p>
      <div class="share-link-copy">
        <input id="share-link-input" type="text" value="" readonly aria-label="Page link" />
        <button id="copy-link-btn" type="button" aria-label="Copy link">
          <svg width="20" height="20" aria-hidden="true"><use href={`${iconsUrl}#icon-copy`}/></svg>
        </button>
      </div>
    </form>
  </div>
</footer>
<script>
  import iconsUrl from '../assets/icons.svg?url';

  let shareController: AbortController | null = null;

  function setupShareButton() {
    shareController?.abort();
    shareController = new AbortController();
    const { signal } = shareController;

    function getShareIconId() {
      const ua = navigator.userAgent;
      if (/iPad|iPhone|iPod/.test(ua)) return 'icon-share-ios';
      if (/Android/.test(ua)) return 'icon-share-android';
      return 'icon-share-ios';
    }

    const shareBtn = document.getElementById('share-btn');
    const shareIcon = document.querySelector('.share-icon use');
    if (shareIcon) {
      const iconId = getShareIconId();
      // Only re-set href when the declarative default ('icon-share-ios')
      // isn't right — WebKit invalidates <use> shadow content if you
      // setAttribute on it unnecessarily, leaving an empty render on iOS.
      if (iconId !== 'icon-share-ios') {
        shareIcon.setAttribute('href', iconsUrl + '#' + iconId);
      }
      if (iconId === 'icon-share-android' && shareBtn) {
        shareBtn.title = 'Android Share';
      }
    }

    const dialog = document.getElementById('share-dialog');
    const shareInput = document.getElementById('share-link-input') as HTMLInputElement | null;
    const copyBtn = document.getElementById('copy-link-btn');

    if (!shareBtn) return;

    if (navigator.share) {
      // Native share — bypass the dialog entirely
      shareBtn.addEventListener('click', () => {
        navigator.share({
          title: document.title,
          url: window.location.href,
        }).catch((err) => {
          if (err?.name !== 'AbortError' && err?.name !== 'InvalidStateError') {
            console.error(err);
          }
        });
      }, { signal });
    } else if (dialog && shareInput && copyBtn) {
      // Popover fallback
      shareBtn.addEventListener('click', () => {
        shareInput.value = window.location.href;
        dialog.showPopover();
        shareInput.select();
      }, { signal });

      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(shareInput.value).then(() => {
          copyBtn.setAttribute('data-copied', '');
          setTimeout(() => copyBtn.removeAttribute('data-copied'), 1500);
        });
      }, { signal });
    }
  }
  document.addEventListener('astro:page-load', setupShareButton);
</script>

