---
import { formatDate } from '../lib/date';

interface Props {
  post: {
    id: string;
    data: {
      date?: Date;
      tags?: string[];
    };
  };
}

const { post } = Astro.props;

const dateStr = post.data.date ? formatDate(new Date(post.data.date)) : '';
const isoDate = post.data.date?.toISOString() ?? '';
const tags = post.data.tags ?? [];
---

<div>
  <div class="meta">
    {dateStr && <time datetime={isoDate}>{dateStr}</time>}
    {dateStr && tags.length > 0 && <span> &middot; </span>}
    {tags.map((tag) => (
      <a class="p-category" href={`/tags/${tag}/`}>#{tag} </a>
    ))}
  </div>
</div>
