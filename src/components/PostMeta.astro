---
import { formatDate } from '../lib/date';

interface Props {
  post: {
    id: string;
    data: {
      date?: Date;
      tags?: string[];
    };
  };
}

const { post } = Astro.props;

const dateStr = post.data.date ? formatDate(new Date(post.data.date)) : '';
const isoDate = post.data.date?.toISOString() ?? '';
const tags = post.data.tags ?? [];
---

<footer class="post-meta-footer">
  <div class="post-meta-footer-row">
    {dateStr && <time datetime={isoDate}>{dateStr}</time>}
    {dateStr && tags.length > 0 && <span> &middot; </span>}
    {tags.map((tag) => (
      <a class="p-category" href={`/tags/${tag}/`}>#{tag} </a>
    ))}
  </div>
  <button id="share-btn" type="button" title="Share this post" class="filter-btn share-btn" popovertarget="share-popover">
    <span>Share</span>
    <svg class="share-icon icon" width="20" height="20" aria-hidden="true">
      <use href="/icons.svg#icon-share-ios" />
    </svg>
  </button>
  <div id="share-popover" popover class="share-popover">
    <label for="share-link-input">Share</label>
    <input id="share-link-input" type="text" value="" readonly />
    <button id="copy-link-btn" type="button">Copy Link</button>
  </div>
</footer>
<script>
  function setupShareButton() {
    function getShareIconId() {
      const ua = navigator.userAgent;
      if (/iPad|iPhone|iPod/.test(ua)) return 'icon-share-ios';
      if (/Android/.test(ua)) return 'icon-share-android';
      return 'icon-share-ios';
    }

    const shareBtn = document.getElementById('share-btn');
    const shareIcon = document.querySelector('.share-icon use');
    if (shareIcon) {
      const iconId = getShareIconId();
      // Only re-set href when the declarative default ('icon-share-ios')
      // isn't right — WebKit invalidates <use> shadow content if you
      // setAttribute on it unnecessarily, leaving an empty render on iOS.
      if (iconId !== 'icon-share-ios') {
        shareIcon.setAttribute('href', '/icons.svg#' + iconId);
      }
      if (iconId === 'icon-share-android' && shareBtn) {
        shareBtn.title = 'Android Share';
      }
    }

    const sharePopover = document.getElementById('share-popover');
    const shareInput = document.getElementById('share-link-input') as HTMLInputElement | null;
    const copyBtn = document.getElementById('copy-link-btn');

    if (shareBtn && navigator.share) {
      // Native share — override the popover toggle with share API
      shareBtn.removeAttribute('popovertarget');
      if (!shareBtn.dataset.shareBound) {
        shareBtn.dataset.shareBound = 'true';
        shareBtn.addEventListener('click', () => {
          navigator.share({
            title: document.title,
            url: window.location.href
          }).catch((err) => {
            if (err?.name !== 'AbortError' && err?.name !== 'InvalidStateError') {
              console.error(err);
            }
          });
        });
      }
    } else if (sharePopover && shareInput && copyBtn) {
      // Popover fallback — populate URL when shown
      sharePopover.addEventListener('toggle', (e) => {
        if ((e as ToggleEvent).newState === 'open') {
          shareInput.value = window.location.href;
          shareInput.select();
        }
      });
      if (!copyBtn.dataset.shareBound) {
        copyBtn.dataset.shareBound = 'true';
        copyBtn.addEventListener('click', () => {
          navigator.clipboard.writeText(shareInput.value).then(() => {
            copyBtn.textContent = 'Copied!';
            setTimeout(() => { copyBtn.textContent = 'Copy Link'; }, 1500);
          }).catch(() => {
            copyBtn.textContent = 'Copy failed';
            setTimeout(() => { copyBtn.textContent = 'Copy Link'; }, 1500);
          });
        });
      }
    }
  }
  document.addEventListener('astro:page-load', setupShareButton);
</script>
