---
import iconsUrl from '../assets/icons.svg?url';
---

<input type="checkbox" id="theme-toggle" aria-label="Toggle dark mode" />
<label for="theme-toggle">
  <span class="theme-icon theme-icon--moon">
    <svg width="20" height="20" aria-hidden="true"><use href={`${iconsUrl}#icon-moon`}/></svg>
  </span>
  <span class="theme-icon theme-icon--sun">
    <svg width="20" height="20" aria-hidden="true"><use href={`${iconsUrl}#icon-sun`}/></svg>
  </span>
</label>

<script>
  let animatingTimer: number | undefined;
  let themeTimer: number | undefined;

  function applyTheme(isDark: boolean) {
    document.documentElement.classList.toggle('dark', isDark);
    const toggle = document.getElementById('theme-toggle') as HTMLInputElement | null;
    if (toggle) toggle.checked = isDark;
    const color = isDark ? '#212121' : '#ffffff';
    document.querySelectorAll('meta[name="theme-color"]').forEach((meta) => {
      meta.setAttribute('content', color);
    });
    try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (e) {}
  }

  function syncTheme(isDark: boolean, animate = false) {
    const html = document.documentElement;
    if (animate) {
      const direction = isDark ? 'theme-to-dark' : 'theme-to-light';
      html.classList.add('theme-animating', direction);
      clearTimeout(animatingTimer);
      clearTimeout(themeTimer);
      themeTimer = window.setTimeout(() => applyTheme(isDark), 400);
      animatingTimer = window.setTimeout(() => {
        html.classList.remove('theme-animating', direction);
      }, 850);
      return;
    }
    applyTheme(isDark);
  }

  document.addEventListener('astro:page-load', () => {
    // Re-apply saved theme after client-side navigation (no animation)
    const saved = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = saved === 'dark' || (!saved && prefersDark);
    syncTheme(isDark);

    document.getElementById('theme-toggle')?.addEventListener('change', (e) => {
      syncTheme((e.target as HTMLInputElement).checked, true);
    });
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) syncTheme(e.matches, true);
  });
</script>
