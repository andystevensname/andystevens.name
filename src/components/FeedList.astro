---
import FeedItem from './FeedItem.astro';
import type { FeedItemData } from '../lib/feed';

interface Props {
  title: string;
  feed: FeedItemData[];
  emptyMessage?: string;
  type?: FeedItemData['type'];
}

const { title, feed, emptyMessage = 'Nothing here yet.', type } = Astro.props;
---

<h1 data-type={type}>{title}</h1>
<section class="feed h-feed">
  <span class="p-name" style="display:none" aria-hidden="true">Andy Stevens — {title}</span>
  <a class="p-author h-card" href="https://andystevens.name" style="display:none" aria-hidden="true" tabindex="-1">Andy Stevens</a>
  {feed.length > 0
    ? feed.map((item, i) => <FeedItem {...item} eager={i < 4} priority={i < 2} />)
    : <p>{emptyMessage}</p>
  }
</section>
