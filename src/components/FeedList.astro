---
import FeedItem from './FeedItem.astro';
import type { FeedItemData } from '../lib/feed';

interface Props {
  title: string;
  feed: FeedItemData[];
  emptyMessage?: string;
}

const { title, feed, emptyMessage = 'Nothing here yet.' } = Astro.props;
---

<h1>{title}</h1>
<section class="recent-feed h-feed">
  <span class="p-name" style="display:none" aria-hidden="true">Andy Stevens — {title}</span>
  <a class="p-author h-card" href="https://andystevens.name" style="display:none" aria-hidden="true" tabindex="-1">Andy Stevens</a>
  {feed.length > 0
    ? feed.map((item) => <FeedItem {...item} />)
    : <p>{emptyMessage}</p>
  }
</section>
