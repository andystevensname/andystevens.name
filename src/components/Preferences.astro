---
import iconsUrl from '../assets/icons.svg?url';

const vapidKey = import.meta.env.VAPID_PUBLIC_KEY ?? '';
---

<button
  id="preferences-btn"
  type="button"
  aria-label="Preferences"
  popovertarget="preferences-popover"
>
  <svg width="20" height="20" aria-hidden="true">
    <use href={`${iconsUrl}#icon-settings`} />
  </svg>
</button>

<div
  id="preferences-popover"
  class="popover-card"
  popover
  role="dialog"
  aria-label="Preferences"
  data-vapid-key={vapidKey}
>
  <div class="popover-handle" aria-hidden="true"></div>
  <div class="preferences-content">
    <h2>Preferences</h2>

    <section class="prefs-section" id="prefs-notifications">
      <div class="prefs-row">
        <div class="prefs-row-text">
          <h3>Notifications</h3>
          <p class="prefs-desc">A push when there's a new post. No other messages.</p>
        </div>
        <label class="prefs-toggle">
          <input type="checkbox" id="prefs-notify-toggle" disabled />
          <span class="prefs-toggle-track" aria-hidden="true">
            <span class="prefs-toggle-thumb"></span>
          </span>
        </label>
      </div>
      <div class="prefs-state" data-state="loading">
        <p data-when="unsupported" class="prefs-note">Your browser doesn't support web push notifications.</p>
        <p data-when="ios-needs-install" class="prefs-note">On iOS, install this site to your home screen first (Share → Add to Home Screen), then return here to enable.</p>
        <p data-when="denied" class="prefs-note">Notifications are blocked. Allow notifications for this site in your browser settings, then reload.</p>
        <p data-when="error" class="prefs-error"></p>
      </div>
    </section>
  </div>
</div>

<script>
  import { onPageLoad } from '../lib/page-load.js';

  const VAPID_KEY = (document.getElementById('preferences-popover') as HTMLElement | null)?.dataset.vapidKey || '';

  function urlBase64ToUint8Array(b64: string): Uint8Array<ArrayBuffer> {
    const padding = '='.repeat((4 - (b64.length % 4)) % 4);
    const base64 = (b64 + padding).replace(/-/g, '+').replace(/_/g, '/');
    const raw = atob(base64);
    const arr = new Uint8Array(raw.length);
    for (let i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
    return arr;
  }

  type State = 'loading' | 'unsupported' | 'ios-needs-install' | 'default' | 'granted-not-subscribed' | 'subscribed' | 'denied' | 'error';

  function setState(state: State, message?: string) {
    const root = document.querySelector('.prefs-state') as HTMLElement | null;
    const toggle = document.getElementById('prefs-notify-toggle') as HTMLInputElement | null;
    if (!root || !toggle) return;
    root.dataset.state = state;
    root.querySelectorAll<HTMLElement>('[data-when]').forEach((el) => {
      el.style.display = el.dataset.when === state ? '' : 'none';
    });
    if (state === 'error' && message) {
      const err = root.querySelector('[data-when="error"]') as HTMLElement | null;
      if (err) err.textContent = message;
    }
    toggle.checked = state === 'subscribed';
    toggle.disabled = state === 'loading'
      || state === 'unsupported'
      || state === 'ios-needs-install'
      || state === 'denied';
  }

  async function detectState(): Promise<State> {
    if (!('serviceWorker' in navigator) || !('PushManager' in window) || !('Notification' in window)) {
      return 'unsupported';
    }
    const isIos = /iPad|iPhone|iPod/.test(navigator.userAgent);
    const standalone = window.matchMedia('(display-mode: standalone)').matches || (navigator as any).standalone === true;
    if (isIos && !standalone) return 'ios-needs-install';

    if (Notification.permission === 'denied') return 'denied';

    const reg = await navigator.serviceWorker.ready;
    const sub = await reg.pushManager.getSubscription();
    if (sub) return 'subscribed';
    if (Notification.permission === 'granted') return 'granted-not-subscribed';
    return 'default';
  }

  async function subscribe() {
    if (!VAPID_KEY) {
      setState('error', 'Site is not configured for notifications.');
      return;
    }
    try {
      const permission = await Notification.requestPermission();
      if (permission !== 'granted') {
        setState(permission === 'denied' ? 'denied' : 'default');
        return;
      }
      const reg = await navigator.serviceWorker.ready;
      const sub = await reg.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlBase64ToUint8Array(VAPID_KEY),
      });
      const res = await fetch('/api/push/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(sub.toJSON()),
      });
      if (!res.ok) throw new Error(`Server returned ${res.status}`);
      setState('subscribed');
    } catch (err) {
      console.error('subscribe failed:', err);
      setState('error', 'Could not enable notifications. Please try again.');
    }
  }

  async function unsubscribe() {
    try {
      const reg = await navigator.serviceWorker.ready;
      const sub = await reg.pushManager.getSubscription();
      if (sub) {
        await fetch('/api/push/unsubscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ endpoint: sub.endpoint }),
        });
        await sub.unsubscribe();
      }
      setState(Notification.permission === 'granted' ? 'granted-not-subscribed' : 'default');
    } catch (err) {
      console.error('unsubscribe failed:', err);
      setState('error', 'Could not disable notifications. Please try again.');
    }
  }

  onPageLoad((signal) => {
    const toggle = document.getElementById('prefs-notify-toggle') as HTMLInputElement | null;
    if (!toggle) return;

    detectState().then((s) => setState(s));

    toggle.addEventListener('change', () => {
      if (toggle.checked) subscribe();
      else unsubscribe();
    }, { signal });
  });
</script>
