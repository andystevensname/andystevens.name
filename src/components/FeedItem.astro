---
interface Props {
  type: 'article' | 'note' | 'bookmark' | 'like' | 'photo' | 'reply' | 'writing' | 'award' | 'album' | 'code';
  url: string;
  date: Date;
  title?: string;
  summary?: string;
  bodyHtml?: string;
  quote?: string;
  linkTo?: string;
  photo?: string;
  alt?: string;
  venue?: string;
  category?: string;
}

import { formatDate } from '../lib/date';

const { type, url, date, title, summary, bodyHtml, quote, linkTo, photo, alt, venue, category } = Astro.props;
---

<article class={`feed-item--${type} h-entry`} data-category={category ?? type}>
  <a href={url}><time datetime={date.toISOString()}>{formatDate(date)}</time></a>
  <div>
    <div class="feed-icon"><svg class="icon" width="20" height="20" aria-hidden="true"><use href={`/icons.svg#icon-${type}`}/></svg></div>
    {type === 'article' && (<>
      <p><a class="p-name u-url" href={url}>{title}</a></p>
      {quote && <p>{quote} <a href={url} aria-label={`Read ${title}`}><svg class="icon" width="20" height="20" aria-hidden="true"><use href="/icons.svg#icon-readmore"/></svg></a></p>}
    </>)}
    {type === 'note' && bodyHtml && (
      <div class="feed-note e-content" set:html={bodyHtml} />
    )}
    {type === 'bookmark' && (<>
      <p><a href={linkTo}>{title ?? linkTo}</a></p>
      {bodyHtml && <div class="e-content" set:html={bodyHtml} />}
    </>)}
    {type === 'like' && (
      <p><a href={linkTo}>{linkTo}</a></p>
    )}
    {type === 'photo' && (<>
      {photo && <a href={url}><img class="u-photo" src={`${photo}?class=photo400`} srcset={`${photo}?class=photo200 200w, ${photo}?class=photo400 400w`} sizes="(min-width: 640px) 40rem, 100vw" alt={alt ?? title ?? ''} loading="lazy" decoding="async" /></a>}
      {title && <p>{title}</p>}
    </>)}
    {type === 'reply' && (<>
      <p>Replied to <a href={linkTo}>{linkTo}</a></p>
      {bodyHtml && <div class="e-content" set:html={bodyHtml} />}
    </>)}
    {type === 'writing' && (<>
      <p>{linkTo ? <a href={linkTo}>{title}</a> : title}</p>
      {(venue || category) && <p>{[venue, category ? category.charAt(0).toUpperCase() + category.slice(1) : ''].filter(Boolean).join(' — ')}</p>}
      {bodyHtml && <div class="e-content" set:html={bodyHtml} />}
    </>)}
    {type === 'award' && (<>
      <p>{title}</p>
      {venue && <p>{venue}</p>}
    </>)}
    {type === 'album' && (<>
      <p><a href={url}>{title}</a></p>
      {photo && <a href={url}><img class="u-photo" src={`${photo}?class=photo400`} srcset={`${photo}?class=photo200 200w, ${photo}?class=photo400 400w`} sizes="(min-width: 640px) 40rem, 100vw" alt={title ?? ''} loading="lazy" decoding="async" /></a>}
      {summary && <p>{summary}</p>}
    </>)}
    {type === 'code' && (<>
      <p><a class="p-name u-url" href={url}>{title}</a></p>
      {summary && <p>{summary}</p>}
    </>)}
  </div>
</article>
