---
import iconsUrl from '../assets/icons.svg?url';

const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/articles/', label: 'Articles' },
  { href: '/commonplace/', label: 'Commonplace' },
  { href: '/writing/', label: 'Writing' },
  { href: '/albums/', label: 'Photography' },
  { href: '/code/', label: 'Code' },
  { href: '/about/', label: 'About' },
];

function isCurrent(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!-- Mobile: dialog-based slide-in nav -->
<dialog id="header-nav-dialog" aria-label="Main navigation">
  <nav>
    <button id="header-nav-dialog-close" aria-label="Close navigation">
      <svg width="20" height="20" aria-hidden="true"><use href={`${iconsUrl}#icon-close`}/></svg>
    </button>
    <ul>
      {links.map(({ href, label }) => (
        <li>
          <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
        </li>
      ))}
    </ul>
  </nav>
</dialog>


<script>
  import { onPageLoad } from '../lib/page-load.js';

  onPageLoad((signal) => {
    const dialog = document.getElementById('header-nav-dialog') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('header-nav-dialog-close') as HTMLButtonElement | null;
    const openBtn = document.getElementById('header-nav-dialog-open') as HTMLButtonElement | null;

    // Open
    document.addEventListener('open-header-nav', () => {
      dialog?.showModal();
    }, { signal });

    // Close button
    closeBtn?.addEventListener('click', () => {
      dialog?.close();
      openBtn?.focus();
    }, { signal });

    // Close on nav link click
    dialog?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => dialog?.close(), { signal });
    });

    // Close on backdrop click
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    }, { signal });

    // Swipe to open/close. Edge + dx are mirrored under RTL so the
    // gesture always originates from the inline-start edge (the same
    // edge the drawer slides in from).
    const EDGE_WIDTH = 30;
    const SWIPE_THRESHOLD = 50;
    let startX = 0;
    let startY = 0;
    let tracking = false;

    const isRtl = () => getComputedStyle(document.documentElement).direction === 'rtl';

    document.addEventListener('pointerdown', (e) => {
      if (dialog?.open) {
        startX = e.clientX;
        startY = e.clientY;
        tracking = true;
      } else if (e.pointerType === 'touch') {
        const fromInlineStartEdge = isRtl()
          ? e.clientX > window.innerWidth - EDGE_WIDTH
          : e.clientX < EDGE_WIDTH;
        if (fromInlineStartEdge) {
          startX = e.clientX;
          startY = e.clientY;
          tracking = true;
        }
      }
    }, { signal });

    document.addEventListener('pointermove', (e) => {
      if (!tracking) return;
      const dx = e.clientX - startX;
      const dy = Math.abs(e.clientY - startY);
      if (dy > Math.abs(dx)) { tracking = false; return; }

      // Convert physical-x delta to inline-axis delta: positive = moving
      // toward inline-end (away from start edge); negative = back toward start.
      const inlineDx = isRtl() ? -dx : dx;

      if (!dialog?.open && inlineDx > SWIPE_THRESHOLD) {
        dialog?.showModal();
        tracking = false;
      } else if (dialog?.open && inlineDx < -SWIPE_THRESHOLD) {
        dialog?.close();
        openBtn?.focus();
        tracking = false;
      }
    }, { signal });

    document.addEventListener('pointerup', () => { tracking = false; }, { signal });
    document.addEventListener('pointercancel', () => { tracking = false; }, { signal });
  });
</script>
