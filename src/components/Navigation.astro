---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/articles/', label: 'Articles' },
  { href: '/commonplace/', label: 'Commonplace' },
  { href: '/writing/', label: 'Writing' },
  { href: '/albums/', label: 'Photography' },
  { href: '/code/', label: 'Code' },
  { href: '/about/', label: 'About' },
];

function isCurrent(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!-- Mobile: dialog-based slide-in nav -->
<dialog id="nav-dialog" aria-label="Main navigation">
  <nav>
    <button id="close-nav-btn" aria-label="Close navigation">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6.758 17.243L12 12M17.243 6.757L12 12M12 12L6.758 6.757M12 12L17.243 17.243"/></svg>
    </button>
    <ul>
      {links.map(({ href, label }) => (
        <li>
          <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
        </li>
      ))}
    </ul>
  </nav>
</dialog>


<script>
  // Abort controller pattern: all listeners attached inside the page-load
  // handler live for exactly one navigation. At the top of each page-load
  // we abort the previous controller (canceling all its listeners at
  // once via the `signal` option) and create a fresh one. Without this,
  // listeners on persistent targets (document, the persisted dialog)
  // accumulate and fire multiple times after each navigation.
  let navController: AbortController | null = null;

  document.addEventListener('astro:page-load', () => {
    navController?.abort();
    navController = new AbortController();
    const { signal } = navController;

    const dialog = document.getElementById('nav-dialog') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('close-nav-btn') as HTMLButtonElement | null;
    const openBtn = document.getElementById('open-nav-btn') as HTMLButtonElement | null;

    // Open
    document.addEventListener('open-nav', () => {
      dialog?.showModal();
    }, { signal });

    // Close button
    closeBtn?.addEventListener('click', () => {
      dialog?.close();
      openBtn?.focus();
    }, { signal });

    // Close on nav link click
    dialog?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => dialog?.close(), { signal });
    });

    // Close on backdrop click
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    }, { signal });

    // Swipe to open/close
    const EDGE_WIDTH = 30;
    const SWIPE_THRESHOLD = 50;
    let startX = 0;
    let startY = 0;
    let tracking = false;

    document.addEventListener('pointerdown', (e) => {
      if (dialog?.open) {
        startX = e.clientX;
        startY = e.clientY;
        tracking = true;
      } else if (e.clientX < EDGE_WIDTH && e.pointerType === 'touch') {
        startX = e.clientX;
        startY = e.clientY;
        tracking = true;
      }
    }, { signal });

    document.addEventListener('pointermove', (e) => {
      if (!tracking) return;
      const dx = e.clientX - startX;
      const dy = Math.abs(e.clientY - startY);
      if (dy > Math.abs(dx)) { tracking = false; return; }

      if (!dialog?.open && dx > SWIPE_THRESHOLD) {
        dialog?.showModal();
        tracking = false;
      } else if (dialog?.open && dx < -SWIPE_THRESHOLD) {
        dialog?.close();
        openBtn?.focus();
        tracking = false;
      }
    }, { signal });

    document.addEventListener('pointerup', () => { tracking = false; }, { signal });
    document.addEventListener('pointercancel', () => { tracking = false; }, { signal });
  });
</script>
