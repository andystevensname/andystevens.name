---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/commonplace/', label: 'Commonplace' },
  { href: '/writing/', label: 'Writing' },
  { href: '/albums/', label: 'Photography' },
  { href: '/about/', label: 'About' },
];

function isCurrent(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!-- Mobile: dialog-based slide-in nav -->
<dialog id="nav-dialog" aria-label="Main navigation">
  <nav>
    <button id="close-nav-btn" aria-label="Close navigation">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" width="20" height="20" fill="currentColor">
        <path d="M342.6 150.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L192 210.7 86.6 105.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L146.7 256 41.4 361.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L192 301.3 297.4 406.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L237.3 256 342.6 150.6z"/>
      </svg>
    </button>
    <ul>
      {links.map(({ href, label }) => (
        <li>
          <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
        </li>
      ))}
    </ul>
  </nav>
</dialog>


<script>
  document.addEventListener('astro:page-load', () => {
    const dialog = document.getElementById('nav-dialog') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('close-nav-btn');
    const openBtn = document.getElementById('open-nav-btn');

    // Open
    document.addEventListener('open-nav', () => {
      dialog?.showModal();
    });

    // Close button
    closeBtn?.addEventListener('click', () => {
      dialog?.close();
      openBtn?.focus();
    });

    // Close on nav link click
    dialog?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => dialog?.close());
    });

    // Close on backdrop click
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    // Swipe to open/close
    const EDGE_WIDTH = 30;
    const SWIPE_THRESHOLD = 50;
    let startX = 0;
    let startY = 0;
    let tracking = false;

    document.addEventListener('pointerdown', (e) => {
      if (dialog?.open) {
        startX = e.clientX;
        startY = e.clientY;
        tracking = true;
      } else if (e.clientX < EDGE_WIDTH && e.pointerType === 'touch') {
        startX = e.clientX;
        startY = e.clientY;
        tracking = true;
      }
    });

    document.addEventListener('pointermove', (e) => {
      if (!tracking) return;
      const dx = e.clientX - startX;
      const dy = Math.abs(e.clientY - startY);
      if (dy > Math.abs(dx)) { tracking = false; return; }

      if (!dialog?.open && dx > SWIPE_THRESHOLD) {
        dialog?.showModal();
        tracking = false;
      } else if (dialog?.open && dx < -SWIPE_THRESHOLD) {
        dialog?.close();
        openBtn?.focus();
        tracking = false;
      }
    });

    document.addEventListener('pointerup', () => { tracking = false; });
    document.addEventListener('pointercancel', () => { tracking = false; });
  });
</script>
