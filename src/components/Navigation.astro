---
---

<nav id="nav">
  <div class="navContainer">
    <button id="close-nav-btn" aria-label="Close navigation">
      <!-- fa-xmark -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" width="20" height="20" fill="currentColor">
        <path d="M342.6 150.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L192 210.7 86.6 105.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L146.7 256 41.4 361.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L192 301.3 297.4 406.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L237.3 256 342.6 150.6z"/>
      </svg>
    </button>
    <ul>
      <li><a href="/" class="nav-link">Home</a></li>
      <li><a href="/blog/" class="nav-link">Blog</a></li>
      <li><a href="/writing/" class="nav-link">Writing</a></li>
      <li><a href="/about/" class="nav-link">About</a></li>
    </ul>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav');

  function openNav() {
    nav?.classList.add('translate-x-0');
  }

  function closeNav() {
    nav?.classList.remove('translate-x-0');
  }

  document.getElementById('close-nav-btn')?.addEventListener('click', closeNav);
  document.addEventListener('open-nav', openNav);
  document.addEventListener('close-nav', closeNav);

  // Close nav when a link is clicked
  nav?.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', closeNav);
  });
</script>
