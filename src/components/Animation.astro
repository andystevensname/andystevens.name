<style>
#animation {
  height: 100vh;
  position: relative;
  overflow: hidden;
}

#gears {
  display: none;
}

#canvas-container {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
}


</style>

<script>
const canvasContainer = document.getElementById('canvas-container');
const gearsContainer = document.getElementById('gears');

if (canvasContainer && gearsContainer) {
  const loadAnimation = async () => {
    const { svgEl, SVG_NS, createBeams, createPoetry, createGears } =
      await import('../lib/animation/index.js');

    const svg = document.createElementNS(SVG_NS, 'svg') as SVGSVGElement;
    svg.style.display = 'block';
    svg.style.width = '100%';
    svg.style.height = '100%';
    svg.style.position = 'absolute';
    svg.style.top = '0';
    svg.style.left = '0';
    canvasContainer.appendChild(svg);

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let beams: ReturnType<typeof createBeams>;
    let poetry: ReturnType<typeof createPoetry>;
    let gears: ReturnType<typeof createGears>;
    let background: SVGGElement;
    let thingsGroup: SVGGElement;
    let poetryGroup: SVGGElement;
    let gadgetsGroup: SVGGElement;
    let cycleStart: number | null = null;
    let lastFramePos = -1;

    function setup() {
      // Clear previous content
      while (svg.firstChild) svg.removeChild(svg.firstChild);

      const w = canvasContainer!.clientWidth;
      const h = canvasContainer!.clientHeight;
      svg.setAttribute('viewBox', `0 0 ${w} ${h}`);

      background = svgEl<SVGGElement>('g');
      svg.appendChild(background);

      gadgetsGroup = svgEl<SVGGElement>('g');
      thingsGroup = svgEl<SVGGElement>('g');
      poetryGroup = svgEl<SVGGElement>('g');
      background.append(gadgetsGroup, thingsGroup, poetryGroup);

      beams = createBeams(thingsGroup, h, w);
      poetry = createPoetry(poetryGroup, w);
      gears = createGears(svg, gadgetsGroup, gearsContainer!, w);

      if (!reducedMotion) {
        // Hide delayed phases before their Web Animations enter active phase.
        // Inner elements have non-zero native opacity (bars 0.75, gears 0.7),
        // so during the animation's "before" phase with fill:none they'd leak
        // through. Explicit group opacity:0 keeps them hidden until the
        // animation takes over.
        poetryGroup.style.opacity = '0';
        gadgetsGroup.style.opacity = '0';

        // Phase sequencing via Web Animations API (survives view transitions)
        const phaseKeyframes = [
          { opacity: 0, offset: 0 },
          { opacity: 1, offset: 0.04 },
          { opacity: 1, offset: 0.293 },
          { opacity: 0, offset: 0.333 },
          { opacity: 0, offset: 1 },
        ];
        const phaseTiming = { duration: 12500, iterations: Infinity };
        thingsGroup.animate(phaseKeyframes, { ...phaseTiming, delay: 0 });
        poetryGroup.animate(phaseKeyframes, { ...phaseTiming, delay: 4170 });
        gadgetsGroup.animate(phaseKeyframes, { ...phaseTiming, delay: 8330 });
      }

      // Re-sync the wall-clock cycle on resize so the new layout's
      // first tick starts at cycle position 0.
      cycleStart = null;
      lastFramePos = -1;
    }

    setup();

    let resizeTimer: number;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(setup, 150);
    });

    if (reducedMotion) return;

    // JS tick handles per-element randomized animations (beam movement,
    // bar vertex jitter). Phase opacity transitions are handled by the
    // Web Animations API above; gears rotate via SMIL.
    //
    // Phase position is derived from wall-clock time, NOT from a
    // per-rAF counter, so that the JS tick stays in lockstep with the
    // Web Animations regardless of display refresh rate. On a 120Hz
    // display, a naive frame counter would complete a 750-frame cycle
    // in ~6.25s while the Web Animations take 12.5s, and the two clocks
    // would drift continuously — bars would jitter while invisible and
    // beams would freeze ~2s before their fade-out.
    const cycleDuration = 12500;
    const totalFrames = 750;

    function tick(now: number) {
      if (cycleStart === null) cycleStart = now;
      const elapsed = (now - cycleStart) % cycleDuration;
      const framePos = Math.floor((elapsed / cycleDuration) * totalFrames);

      // High-refresh displays fire rAF faster than framePos advances;
      // skip duplicate calls so throttles inside animate() stay meaningful.
      if (framePos !== lastFramePos) {
        beams.animate(framePos, 0, 249);
        poetry.animate(framePos, 250, 499);
        gears.animate(framePos, 500, 749);
        lastFramePos = framePos;
      }

      requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  };

  // Wait for layout to settle before measuring container width
  requestAnimationFrame(() => {
    requestAnimationFrame(loadAnimation);
  });
}
</script>
