---
import ThemeSwitcher from './ThemeSwitcher.astro';

const currentPath = Astro.url.pathname;

const links = [
  { href: '/blog/', label: 'Blog' },
  { href: '/commonplace/', label: 'Commonplace' },
  { href: '/writing/', label: 'Writing' },
  { href: '/albums/', label: 'Photography' },
  { href: '/about/', label: 'About' },
];

function isCurrent(href: string): boolean {
  return currentPath.startsWith(href);
}
---

<header id="header">
  <!-- Mobile: hamburger -->
  <button id="open-nav-btn" aria-label="Open navigation" aria-expanded="false" aria-controls="nav-dialog">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5H21"/><path d="M3 12H21"/><path d="M3 19H21"/></svg>
  </button>

  <!-- Desktop: home icon -->
  <a href="/" id="home-link" aria-label="Home">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8L11.7317 3.13416C11.9006 3.04971 12.0994 3.0497 12.2683 3.13416L22 8"/><path d="M20 11V19C20 20.1046 19.1046 21 18 21H6C4.89543 21 4 20.1046 4 19V11"/></svg>
  </a>

  <!-- Desktop: inline nav -->
  <nav id="header-nav" aria-label="Main navigation">
    {links.map(({ href, label }) => (
      <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
    ))}
  </nav>

  <ThemeSwitcher />

  <a href="/" class="title-text-mobile">Andy Makes Things</a>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const header = document.getElementById('header');
    let lastScroll = 0;

    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;
      const atBottom = (window.innerHeight + currentScroll) >= document.documentElement.scrollHeight - 1;
      if (currentScroll <= 0 || atBottom) {
        header?.removeAttribute('data-hidden');
      } else if (currentScroll > lastScroll) {
        header?.setAttribute('data-hidden', '');
      } else if (currentScroll < lastScroll) {
        header?.removeAttribute('data-hidden');
      }
      lastScroll = currentScroll;
    });

    document.getElementById('open-nav-btn')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('open-nav'));
    });
  });
</script>
