---
import ThemeSwitcher from './ThemeSwitcher.astro';

const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/articles/', label: 'Articles' },
  { href: '/commonplace/', label: 'Commonplace' },
  { href: '/writing/', label: 'Writing' },
  { href: '/albums/', label: 'Photography' },
  { href: '/code/', label: 'Code' },
  { href: '/about/', label: 'About' },
];

function isCurrent(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header id="header">
  <!-- Mobile: hamburger -->
  <button id="header-nav-dialog-open" aria-label="Open navigation" aria-expanded="false" aria-controls="header-nav-dialog">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5H21"/><path d="M3 12H21"/><path d="M3 19H21"/></svg>
  </button>

  <!-- Desktop: inline nav -->
  <nav id="header-nav" aria-label="Main navigation">
    {links.map(({ href, label }) => (
      <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
    ))}
  </nav>

  <ThemeSwitcher />

  <a href="/" class="title-text-mobile">Andy Makes Things</a>
</header>

<script>
  // Abort previous page-load's listeners so they don't accumulate on
  // window across navigations. See the equivalent pattern in
  // Navigation.astro for the fuller explanation.
  let headerController: AbortController | null = null;

  document.addEventListener('astro:page-load', () => {
    headerController?.abort();
    headerController = new AbortController();
    const { signal } = headerController;

    const header = document.getElementById('header') as HTMLElement | null;
    let lastScroll = 0;

    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;
      const atBottom = (window.innerHeight + currentScroll) >= document.documentElement.scrollHeight - 1;
      if (currentScroll <= 0 || atBottom) {
        header?.removeAttribute('data-hidden');
      } else if (currentScroll > lastScroll) {
        header?.setAttribute('data-hidden', '');
      } else if (currentScroll < lastScroll) {
        header?.removeAttribute('data-hidden');
      }
      lastScroll = currentScroll;
    }, { signal });

    document.getElementById('header-nav-dialog-open')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('open-header-nav'));
    }, { signal });
  });
</script>
