---
import iconsUrl from '../assets/icons.svg?url';

const HANDLE = 'andy@andystevens.name';
const PROFILE_URL = 'https://andystevens.name';
---

<a
  class="fedi-follow"
  href={PROFILE_URL}
  rel="me"
  data-fedi-handle={HANDLE}
><svg width="1em" height="1em" aria-hidden="true" focusable="false"><use href={`${iconsUrl}#icon-fediverse`}/></svg><span class="label">Fediverse</span></a>

<div id="fedi-follow-dialog" class="popover-card" popover role="dialog" aria-label="Follow on the Fediverse">
  <div class="popover-handle" aria-hidden="true"></div>
  <form id="fedi-follow-form" class="popover-form">
    <div class="fedi-handle-copy">
      <input
        id="fedi-handle"
        type="text"
        value="@andy@andystevens.name"
        readonly
        aria-label="Fediverse handle"
      />
      <button type="button" id="fedi-handle-copy-btn" aria-label="Copy handle">
        <svg width="20" height="20" aria-hidden="true"><use href={`${iconsUrl}#icon-copy`}/></svg>
      </button>
    </div>
    <p>
      This site is federated with ActivityPub. Enter your Fediverse instance or handle below to read and follow.
    </p>
    <label for="fedi-follow-instance">Your server</label>
    <input
      id="fedi-follow-instance"
      name="instance"
      type="text"
      placeholder="e.g. mastodon.social"
      autocomplete="off"
      autocapitalize="off"
      autocorrect="off"
      spellcheck="false"
      required
    />
    <div class="popover-actions">
      <button type="submit">Continue</button>
    </div>
  </form>
</div>

<script>
  import { onPageLoad } from '../lib/page-load.js';
  import { copyToClipboard } from '../lib/clipboard.js';

  const HANDLE = 'andy@andystevens.name';
  const STORAGE_KEY = 'fedi-instance';

  // Accept anything from "mastodon.social" to "https://mastodon.social/@user"
  // to "@user@mastodon.social" — extract just the host.
  function normalizeInstance(input: string): string {
    let s = input.trim().replace(/^https?:\/\//, '').replace(/\/+$/, '');
    if (s.startsWith('@')) {
      const parts = s.slice(1).split('@');
      if (parts.length === 2) s = parts[1];
    }
    if (s.includes('/')) s = s.split('/')[0];
    return s;
  }

  function buildFollowUrl(instance: string): string {
    return `https://${instance}/@${HANDLE}`;
  }

  onPageLoad((signal) => {
    const dialog = document.getElementById('fedi-follow-dialog');
    const form = document.getElementById('fedi-follow-form') as HTMLFormElement | null;
    const input = document.getElementById('fedi-follow-instance') as HTMLInputElement | null;

    if (!dialog || !form || !input) return;

    document.querySelectorAll<HTMLAnchorElement>('a.fedi-follow').forEach((link) => {
      link.addEventListener('click', (e) => {
        // Modifier-clicks fall through to the noscript profile URL.
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        e.preventDefault();

        // Returning visitors with a saved instance skip both attempts.
        const saved = (() => {
          try { return localStorage.getItem(STORAGE_KEY); } catch { return null; }
        })();
        if (saved) {
          window.location.href = buildFollowUrl(saved);
          return;
        }

        // First-timers: try the RFC 7565 acct: URI in case the visitor
        // has a Fediverse client registered as a protocol handler. We
        // use an iframe so unhandled schemes fail silently (Safari
        // surfaces an "address is invalid" alert if you navigate the
        // main window to an unknown scheme; an iframe load failure
        // produces no UI). If the OS hands off to an app, blur or
        // visibilitychange fires and we cancel the dialog fallback.
        // Otherwise (the common case) we show the dialog.
        let handled = false;
        const onLeave = () => { handled = true; };
        window.addEventListener('blur', onLeave, { once: true });
        document.addEventListener('visibilitychange', onLeave, { once: true });

        const iframe = document.createElement('iframe');
        iframe.setAttribute('aria-hidden', 'true');
        iframe.style.cssText = 'position:absolute;width:0;height:0;border:0;visibility:hidden;';
        iframe.src = `acct:${HANDLE}`;
        document.body.appendChild(iframe);

        setTimeout(() => {
          iframe.remove();
          window.removeEventListener('blur', onLeave);
          document.removeEventListener('visibilitychange', onLeave);
          if (!handled) {
            dialog.showPopover();
            input.focus();
          }
        }, 500);
      }, { signal });
    });

    document.getElementById('fedi-handle-copy-btn')?.addEventListener('click', (e) => {
      copyToClipboard(e.currentTarget as HTMLElement, '@andy@andystevens.name');
    }, { signal });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const instance = normalizeInstance(input.value);
      if (!instance) return;
      try { localStorage.setItem(STORAGE_KEY, instance); } catch {}
      window.location.href = buildFollowUrl(instance);
    }, { signal });
  });
</script>

<style>
  .fedi-follow {
    cursor: pointer;
  }

  .fedi-handle-copy {
    flex-basis: 100%;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.25rem;
  }

  .fedi-handle-copy input {
    flex: 1;
    min-width: 0;
    font-size: 1rem;
    padding: 0.5rem;
    border: 1px solid #ccc;
    border-radius: var(--radius-sm);
    background: light-dark(#f8f8f8, #333);
    color: var(--text);
    cursor: text;
    user-select: all;
    margin: 0;
  }

  .fedi-handle-copy button {
    flex-shrink: 0;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--c-gray-light);
    display: flex;
    align-items: center;
  }

  .fedi-handle-copy button:hover,
  .fedi-handle-copy button[data-copied] {
    color: var(--c-accent);
  }
</style>
