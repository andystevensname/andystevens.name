---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Navigation from '../components/Navigation.astro';
import Animation from '../components/Animation.astro';
import FediFollow from '../components/FediFollow.astro';
import iconsUrl from '../assets/icons.svg?url';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  extraHead?: string;
  canonical?: string;
  ogType?: string;
  jsonLd?: Record<string, any>;
  pageType?: string;
}

const { title, description, extraHead, canonical, ogType = 'website', jsonLd, pageType } = Astro.props;
const pageTitle = title ? `${title} — Andy Stevens` : 'Andy Stevens';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const currentYear = new Date().getFullYear();

function pageTypeFromPath(pathname: string): string | undefined {
  if (pathname === '/') return 'home';
  if (pathname.startsWith('/articles/')) return 'article';
  if (pathname.startsWith('/photos/'))   return 'photo';
  if (pathname.startsWith('/albums/'))   return 'album';
  if (pathname.startsWith('/writing/'))  return 'writing';
  if (pathname.startsWith('/awards/'))   return 'award';
  if (pathname.startsWith('/code/'))     return 'code';
  if (pathname.startsWith('/notes/'))    return 'note';
  if (pathname.startsWith('/bookmarks/'))return 'bookmark';
  if (pathname.startsWith('/likes/'))    return 'like';
  if (pathname.startsWith('/replies/'))  return 'reply';
  if (pathname.startsWith('/commonplace/')) return 'commonplace';
  return undefined;
}

const resolvedPageType = pageType ?? pageTypeFromPath(Astro.url.pathname);

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Andy Stevens',
  url: 'https://andystevens.name',
  author: {
    '@type': 'Person',
    name: 'Andy Stevens',
    url: 'https://andystevens.name',
    sameAs: [
      'https://github.com/andystevensname',
      'https://bsky.app/profile/andystevens.name',
    ],
  },
};

const structuredData = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#212121" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Andy Stevens" />
    {description && <meta name="description" content={description} />}
    <title>{pageTitle}</title>

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://media.andystevens.name" />
    <link rel="dns-prefetch" href="https://media.andystevens.name" />
    <link rel="preconnect" href="https://webmention.andystevens.name" />
    <link rel="dns-prefetch" href="https://webmention.andystevens.name" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:site_name" content="Andy Stevens" />

    <!-- rel-me -->
    <link rel="me" href="https://github.com/andystevensname" />
    <link rel="me" href="https://bsky.app/profile/andystevens.name" />

    <!-- IndieWeb endpoints -->
    <link rel="webmention" href="https://webmention.andystevens.name/webmention" />
    <link rel="pingback" href="https://webmention.andystevens.name/pingback" />
    <link rel="micropub" href="https://micropub.stormfield.house/micropub">
    <!-- No authorization/token endpoints: IndieKit is retired. Web
         sign-in ("log in with your domain") works via RelMeAuth — the
         rel="me" GitHub link above links back to this domain. -->

    <!-- Feeds -->
    <link rel="alternate" type="application/rss+xml" title="Andy Stevens" href="/feed.xml" />
    <link rel="feed" type="text/html" href="/" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Anti-FOUC: apply saved theme before paint -->
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (theme === 'dark' || (!theme && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <link rel="preload" as="font" href="/fonts/BebasNeue-Regular.woff2" type="font/woff2" crossorigin="" />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () {});
        });
      }
    </script>
    {extraHead && <Fragment set:html={extraHead} />}
    <ClientRouter />
    <script>import '../lib/photo-nav';</script>
    <script>import '../lib/popover-swipe';</script>
    <script>import '../lib/pull-to-refresh';</script>
  </head>
  <body data-page-type={resolvedPageType}>
    <svg id="ptr-indicator" viewBox="-2 -2 44 44" aria-hidden="true">
      <defs>
        <linearGradient id="ptr-gradient" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="var(--c-accent)"/>
          <stop offset="100%" stop-color="var(--text)"/>
        </linearGradient>
      </defs>
      <path id="ptr-shape" d="M20 2 A18 18 0 1 1 19.99 2 Z" fill="url(#ptr-gradient)" fill-opacity="0" stroke="currentColor" stroke-width="2" style="opacity:0"/>
    </svg>
    <a href="#main-content">Skip to content</a>
    <!-- Representative h-card (visually hidden, machine-readable) -->
    <div class="h-card sr-only" aria-hidden="true">
      <a class="p-name u-url u-uid" href="https://andystevens.name" rel="me" tabindex="-1">Andy Stevens</a>
      <span class="p-note">Poet, technical writer, and web tinkerer.</span>
      <a class="u-url" href="https://github.com/andystevensname" rel="me" tabindex="-1">GitHub</a>
      <a class="u-url" href="https://bsky.app/profile/andystevens.name" rel="me" tabindex="-1">Bluesky</a>
    </div>
    <Header />
    <Navigation />
    <main id="site-layout">
      <div id="site-title" aria-hidden="true"><span>Andy</span> <span>Makes</span> <span>Things</span></div>
      <div id="site-sidebar" aria-hidden="true" transition:persist="sidebar">
        <Animation />
      </div>
      <section id="main-content">
        <slot />
      </section>
    </main>
    <footer id="footer">
      <span>&copy; 2021&ndash;{currentYear} Andy Stevens</span>
      <div class="social-links">
        <a rel="me" href="https://github.com/andystevensname">
          <svg width="1em" height="1em" aria-hidden="true" focusable="false"><use href={`${iconsUrl}#icon-github`}/></svg>
          <span class="label">GitHub</span>
        </a>
        <FediFollow />
        <a rel="me" href="https://bsky.app/profile/andystevens.name">
          <svg width="1em" height="1em" aria-hidden="true" focusable="false"><use href={`${iconsUrl}#icon-bluesky`}/></svg>
          <span class="label">Bluesky</span>
        </a>
        <a href="/feed.xml">
          <svg width="1em" height="1em" aria-hidden="true" focusable="false"><use href={`${iconsUrl}#icon-rss`}/></svg>
          <span class="label">RSS</span>
        </a>
      </div>
    </footer>
  </body>
</html>
