---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Navigation from '../components/Navigation.astro';
import Animation from '../components/Animation.astro';
import FediFollow from '../components/FediFollow.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  extraHead?: string;
  canonical?: string;
  ogType?: string;
  jsonLd?: Record<string, any>;
  pageType?: string;
}

const { title, description, extraHead, canonical, ogType = 'website', jsonLd, pageType } = Astro.props;
const pageTitle = title ? `${title} — Andy Stevens` : 'Andy Stevens';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const currentYear = new Date().getFullYear();

function pageTypeFromPath(pathname: string): string | undefined {
  if (pathname === '/') return 'home';
  if (pathname.startsWith('/articles/')) return 'article';
  if (pathname.startsWith('/photos/'))   return 'photo';
  if (pathname.startsWith('/albums/'))   return 'album';
  if (pathname.startsWith('/writing/'))  return 'writing';
  if (pathname.startsWith('/awards/'))   return 'award';
  if (pathname.startsWith('/code/'))     return 'code';
  if (pathname.startsWith('/notes/'))    return 'note';
  if (pathname.startsWith('/bookmarks/'))return 'bookmark';
  if (pathname.startsWith('/likes/'))    return 'like';
  if (pathname.startsWith('/replies/'))  return 'reply';
  if (pathname.startsWith('/commonplace/')) return 'commonplace';
  return undefined;
}

const resolvedPageType = pageType ?? pageTypeFromPath(Astro.url.pathname);

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Andy Stevens',
  url: 'https://andystevens.name',
  author: {
    '@type': 'Person',
    name: 'Andy Stevens',
    url: 'https://andystevens.name',
    sameAs: [
      'https://github.com/andystevensname',
      'https://bsky.app/profile/andystevens.name',
    ],
  },
};

const structuredData = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#212121" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {description && <meta name="description" content={description} />}
    <title>{pageTitle}</title>

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://media.andystevens.name" />
    <link rel="dns-prefetch" href="https://media.andystevens.name" />
    <link rel="preconnect" href="https://webmention.andystevens.name" />
    <link rel="dns-prefetch" href="https://webmention.andystevens.name" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:site_name" content="Andy Stevens" />

    <!-- rel-me -->
    <link rel="me" href="https://github.com/andystevensname" />
    <link rel="me" href="https://bsky.app/profile/andystevens.name" />

    <!-- IndieWeb endpoints -->
    <link rel="webmention" href="https://webmention.andystevens.name/webmention" />
    <link rel="pingback" href="https://webmention.andystevens.name/pingback" />
    <link rel="micropub" href="https://ik.andystevens.name/micropub">
    <link rel="authorization_endpoint" href="https://ik.andystevens.name/auth">
    <link rel="token_endpoint" href="https://ik.andystevens.name/auth/token">

    <!-- Feeds -->
    <link rel="alternate" type="application/rss+xml" title="Andy Stevens" href="/feed.xml" />
    <link rel="feed" type="text/html" href="/" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Anti-FOUC: apply saved theme before paint -->
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (theme === 'dark' || (!theme && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <link rel="preload" as="font" href="/fonts/BebasNeue-Regular.woff2" type="font/woff2" crossorigin="" />
    {extraHead && <Fragment set:html={extraHead} />}
    <ClientRouter />
    <script>import '../lib/photo-nav';</script>
  </head>
  <body data-page-type={resolvedPageType}>
    <a href="#main-content">Skip to content</a>
    <!-- Representative h-card (visually hidden, machine-readable) -->
    <div class="h-card sr-only" aria-hidden="true">
      <a class="p-name u-url u-uid" href="https://andystevens.name" rel="me" tabindex="-1">Andy Stevens</a>
      <span class="p-note">Poet, technical writer, and web tinkerer.</span>
      <a class="u-url" href="https://github.com/andystevensname" rel="me" tabindex="-1">GitHub</a>
      <a class="u-url" href="https://bsky.app/profile/andystevens.name" rel="me" tabindex="-1">Bluesky</a>
    </div>
    <Header />
    <Navigation />
    <main id="site-layout">
      <div id="site-title" aria-hidden="true"><span>Andy</span> <span>Makes</span> <span>Things</span></div>
      <div id="site-sidebar" aria-hidden="true" transition:persist="sidebar">
        <Animation />
      </div>
      <section id="main-content">
        <slot />
      </section>
    </main>
    <footer id="footer">
      <span>&copy; 2021&ndash;{currentYear} Andy Stevens</span>
      <div class="social-links">
        <a rel="me" href="https://github.com/andystevensname">
          <svg width="1em" height="1em" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M14.3333 19V17.137C14.3583 16.8275 14.3154 16.5163 14.2073 16.2242C14.0993 15.9321 13.9286 15.6657 13.7067 15.4428C15.8 15.2156 18 14.4431 18 10.8989C17.9998 9.99256 17.6418 9.12101 17 8.46461C17.3039 7.67171 17.2824 6.79528 16.94 6.01739C16.94 6.01739 16.1533 5.7902 14.3333 6.97811C12.8053 6.57488 11.1947 6.57488 9.66666 6.97811C7.84666 5.7902 7.05999 6.01739 7.05999 6.01739C6.71757 6.79528 6.69609 7.67171 6.99999 8.46461C6.35341 9.12588 5.99501 10.0053 5.99999 10.9183C5.99999 14.4366 8.19999 15.2091 10.2933 15.4622C10.074 15.6829 9.90483 15.9461 9.79686 16.2347C9.68889 16.5232 9.64453 16.8306 9.66666 17.137V19" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9.66667 17.7018C7.66667 18.3335 6 17.7018 5 15.7544" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="label">GitHub</span>
        </a>
        <FediFollow />
        <a rel="me" href="https://bsky.app/profile/andystevens.name">
          <svg width="1em" height="1em" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"/>
          </svg>
          <span class="label">Bluesky</span>
        </a>
        <a href="/feed.xml">
          <svg width="1em" height="1em" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M12 19C12 14.82 8.66 12 5 12" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M19 19C19 10.27 13.73 5 5 5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M5 19C5.55228 19 6 18.5523 6 18C6 17.4477 5.55228 17 5 17C4.44772 17 4 17.4477 4 18C4 18.5523 4.44772 19 5 19Z" fill="currentColor" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="label">RSS</span>
        </a>
      </div>
    </footer>
  </body>
</html>
