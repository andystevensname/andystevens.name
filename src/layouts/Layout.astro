---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Navigation from '../components/Navigation.astro';
import Animation from '../components/Animation.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  extraHead?: string;
  canonical?: string;
  ogType?: string;
  jsonLd?: Record<string, any>;
}

const { title, description, extraHead, canonical, ogType = 'website', jsonLd } = Astro.props;
const pageTitle = title ? `${title} — Andy Stevens` : 'Andy Stevens';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const currentYear = new Date().getFullYear();

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Andy Stevens',
  url: 'https://andystevens.name',
  author: {
    '@type': 'Person',
    name: 'Andy Stevens',
    url: 'https://andystevens.name',
    sameAs: [
      'https://github.com/andystevensname',
      'https://bsky.app/profile/andystevens.name',
    ],
  },
};

const structuredData = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#212121" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {description && <meta name="description" content={description} />}
    <title>{pageTitle}</title>

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://media.andystevens.name" />
    <link rel="dns-prefetch" href="https://media.andystevens.name" />
    <link rel="preconnect" href="https://webmention.andystevens.name" />
    <link rel="dns-prefetch" href="https://webmention.andystevens.name" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:site_name" content="Andy Stevens" />

    <!-- rel-me -->
    <link rel="me" href="https://github.com/andystevensname" />
    <link rel="me" href="https://bsky.app/profile/andystevens.name" />

    <!-- IndieWeb endpoints -->
    <link rel="webmention" href="https://webmention.andystevens.name/webmention" />
    <link rel="micropub" href="https://ik.andystevens.name/micropub">
    <link rel="authorization_endpoint" href="https://ik.andystevens.name/auth">
    <link rel="token_endpoint" href="https://ik.andystevens.name/auth/token">

    <!-- Feeds -->
    <link rel="alternate" type="application/rss+xml" title="Andy Stevens" href="/feed.xml" />
    <link rel="feed" type="text/html" href="/" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Anti-FOUC: apply saved theme before paint -->
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (theme === 'dark' || (!theme && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <link rel="preload" as="font" href="/fonts/InstrumentSerif.woff2" type="font/woff2" crossorigin="" />
    {extraHead && <Fragment set:html={extraHead} />}
    <ClientRouter />
    <script>import '../lib/photo-nav';</script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <!-- Representative h-card (visually hidden, machine-readable) -->
    <div class="h-card" id="representative-hcard" aria-hidden="true">
      <a class="p-name u-url u-uid" href="https://andystevens.name" rel="me" tabindex="-1">Andy Stevens</a>
      <span class="p-note">Poet, technical writer, and web tinkerer.</span>
      <a class="u-url" href="https://github.com/andystevensname" rel="me" tabindex="-1">GitHub</a>
      <a class="u-url" href="https://bsky.app/profile/andystevens.name" rel="me" tabindex="-1">Bluesky</a>
    </div>
    <div id="content">
      <Header />
      <Navigation />
      <main id="site-layout">
        <div id="site-title" aria-hidden="true"><span>Andy</span> <span>Makes</span> <span>Things</span></div>
        <div id="site-sidebar" aria-hidden="true" transition:persist="sidebar">
          <Animation />
        </div>
        <section id="main-content">
          <slot />
        </section>
      </main>
      <footer id="footer">
        &copy; 2021&ndash;{currentYear} Andy Stevens
        <span aria-hidden="true">&middot;</span>
        <a rel="me" href="https://github.com/andystevensname">GitHub</a>
        <span aria-hidden="true">&middot;</span>
        <a rel="me" href="https://bsky.app/profile/andystevens.name">Bluesky</a>
      </footer>
    </div>
  </body>
</html>
