    "@sveltia/cms": "^0.170.5",
    "astro": "^6.1.10",
    "marked": "^17.0.5",
    "remark-directive": "^4.0.0",
    "unist-util-visit": "^5.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@bunny.net/edgescript-sdk": "^0.12.1",
    "@resvg/resvg-js": "^2.6.2",
    "esbuild": "^0.28.0",
    "fontkit": "^2.0.4",
    "gray-matter": "^4.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
